{
	"name": "huggingface-sync",
	"author": "JacobLinCool <jacob@csie.cool> (https://jacoblin.cool)",
	"license": "MIT",
	"version": "1.4.0",
	"description": "Sync your GitHub repository to Hugging Face Spaces.",
	"files": [
		"dist",
		"action.yml",
		"README.md"
	],
	"scripts": {
		"prepare": "husky",
		"format": "prettier --write --ignore-path .gitignore .",
		"test": "jest --coverage",
		"changeset": "changeset",
		"build": "esbuild src/index.ts --platform=node --bundle --outfile=dist/index.js"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@types/fs-extra": "^11.0.4",
		"@types/jest": "^30.0.0",
		"@types/node": "^24.10.0",
		"esbuild": "^0.28.0",
		"husky": "^9.1.7",
		"jest": "^30.4.2",
		"lint-staged": "^17.0.4",
		"prettier": "^3.8.3",
		"prettier-plugin-organize-imports": "^4.3.0",
		"serve": "^14.2.6",
		"ts-jest": "^29.4.9",
		"tsup": "^8.5.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"*.{ts,js,json,yaml,yml}": [
			"prettier --write"
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/JacobLinCool/huggingface-sync.git"
	},
	"bugs": {
		"url": "https://github.com/JacobLinCool/huggingface-sync/issues"
	},
	"homepage": "https://jacoblincool.github.io/huggingface-sync",
	"packageManager": "pnpm@11.1.2",
	"dependencies": {
		"@actions/core": "^3.0.1",
		"@actions/github": "^9.1.1",
		"fs-extra": "^11.3.5"
	}
}
